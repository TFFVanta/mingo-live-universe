{
  "name": "mingo-live-universe",
  "version": "0.1.0",
  "private": true,
  "description": "Live 3D story universe and immersive world engine for MINGO.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:world": "npm --workspace apps/demo-world run dev",
    "dev:sim": "node apps/simulation-server/src/server.js",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
